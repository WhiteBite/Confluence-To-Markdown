{
    "name": "confluence-to-markdown",
    "version": "3.1.4",
    "description": "Confluence pages to Markdown exporter with diagram conversion",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "node scripts/sync-version.js && vite build && echo Script ready at http://localhost:8765/confluence-to-markdown.user.js",
        "build:ext": "node scripts/sync-version.js && vite build --config vite.config.extension.ts && vite build --config vite.config.background.ts && node scripts/copy-assets.js",
        "preview": "vite preview",
        "serve": "http-server dist -p 8765 --cors -c-1",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ --ext .ts",
        "lint:fix": "eslint src/ --ext .ts --fix",
        "sync-version": "node scripts/sync-version.js"
    },
    "dependencies": {
        "@whitebite/diagram-converter": "^0.2.0",
        "fflate": "^0.8.2",
        "turndown": "^7.2.0",
        "turndown-plugin-gfm": "^1.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/chrome": "^0.0.268",
        "@types/turndown": "^5.0.5",
        "eslint-plugin-userscripts": "^0.5.6",
        "jsdom": "^24.0.0",
        "playwright": "^1.57.0",
        "terser": "^5.46.2",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^5.4.11",
        "vite-plugin-monkey": "^4.0.6",
        "vitest": "^1.6.0"
    }
}
